\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Initiation seed --- Weddell margin ($-62.96/-66.81$), \texttt  {\small  movcav8} v4 restart.} \emph  {Top:} plan view at $\sim $95\,m (level~11). Note the isolated \textbf  {fresh column ($S\approx 31$)} at the ice front (black outline), the \textbf  {all-black speed panel} (\texttt  {\small  u}/\texttt  {\small  v}$=0$ across the opened region), and the $w$ dipole on the front. Grey $=$ cavity/deep (no data at this level, \emph  {not} land). \emph  {Bottom:} lat--depth section on a \textbf  {layer-index axis} (equal layers; depth on the right) --- the fresh column runs full-depth under a thin hatched ice cap, against $S\approx 34$ open water, with the $w$ down/upwelling curtain at the front. The state has strong fronts but \emph  {zero} balancing flow.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:initstate}{{1}{4}{\textbf {Initiation seed --- Weddell margin ($-62.96/-66.81$), \code {movcav8} v4 restart.} \emph {Top:} plan view at $\sim $95\,m (level~11). Note the isolated \textbf {fresh column ($S\approx 31$)} at the ice front (black outline), the \textbf {all-black speed panel} (\code {u}/\code {v}$=0$ across the opened region), and the $w$ dipole on the front. Grey $=$ cavity/deep (no data at this level, \emph {not} land). \emph {Bottom:} lat--depth section on a \textbf {layer-index axis} (equal layers; depth on the right) --- the fresh column runs full-depth under a thin hatched ice cap, against $S\approx 34$ open water, with the $w$ down/upwelling curtain at the front. The state has strong fronts but \emph {zero} balancing flow}{figure.1}{}}
