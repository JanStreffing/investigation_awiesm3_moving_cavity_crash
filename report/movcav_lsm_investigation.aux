\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Map evolution at $\sim $95\,m in the Totten margin} ($T$ | $S$ | $w$; star $=$ crash cell 108.7/$-$66.1). \emph  {Top:} hour~1 --- smooth $T$/$S$, $w\approx 0$. \emph  {Bottom:} hour~85 ($\sim $day~3.5) --- a fresh ($<30$\,PSU) $+$ cold band has grown along the whole retreated margin with intensifying up/down $w$ cells. Frames from \texttt  {\footnotesize  blowup\_TSw\_evolution.mp4}.}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:mapevo}{{3}{9}{\textbf {Map evolution at $\sim $95\,m in the Totten margin} ($T$ | $S$ | $w$; star $=$ crash cell 108.7/$-$66.1). \emph {Top:} hour~1 --- smooth $T$/$S$, $w\approx 0$. \emph {Bottom:} hour~85 ($\sim $day~3.5) --- a fresh ($<30$\,PSU) $+$ cold band has grown along the whole retreated margin with intensifying up/down $w$ cells. Frames from \file {blowup\_TSw\_evolution.mp4}}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Cross-margin vertical section} at lon\,$\approx $\,108.73$^\circ $E (S\,$\to $\,ice-shelf, N\,$\to $\,open ocean; dashed line $=$ crash latitude $-66.09^\circ $). \emph  {Top:} hour~1 --- cavity side is \emph  {uniform $\sim $34\,PSU full-depth}, $w\approx 0$. \emph  {Bottom:} hour~101 ($\sim $day~4.2) --- a \textbf  {full-depth fresh ($<29$\,PSU) $+$ cold water mass} has developed on the cavity side, sharply fronted against the $34$--$35$\,PSU open ocean, with the $w$ runaway as a \textbf  {vertical curtain at the $-66^\circ $ front}. This is the clearest single view of the instability \emph  {amplifying in time} from a value-clean but dynamically-unbalanced start (\S  \ref {sec:rev3}). Frames from \texttt  {\footnotesize  blowup\_section\_evolution.mp4}.}}{10}{figure.4}\protected@file@percent }
\newlabel{fig:sectevo}{{4}{10}{\textbf {Cross-margin vertical section} at lon\,$\approx $\,108.73$^\circ $E (S\,$\to $\,ice-shelf, N\,$\to $\,open ocean; dashed line $=$ crash latitude $-66.09^\circ $). \emph {Top:} hour~1 --- cavity side is \emph {uniform $\sim $34\,PSU full-depth}, $w\approx 0$. \emph {Bottom:} hour~101 ($\sim $day~4.2) --- a \textbf {full-depth fresh ($<29$\,PSU) $+$ cold water mass} has developed on the cavity side, sharply fronted against the $34$--$35$\,PSU open ocean, with the $w$ runaway as a \textbf {vertical curtain at the $-66^\circ $ front}. This is the clearest single view of the instability \emph {amplifying in time} from a value-clean but dynamically-unbalanced start (\S \ref {sec:rev3}). Frames from \file {blowup\_section\_evolution.mp4}}{figure.4}{}}
