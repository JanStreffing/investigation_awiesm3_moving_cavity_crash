\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Two other high-\texttt  {\small  CFLz} sites --- both benign at $t=0$, confirming the seed is elsewhere.} \emph  {Top:} the peak-\texttt  {\small  CFLz} cell (90.5/$-$63.5, level~38, \textbf  {3775\,m}) is \textbf  {fully-unchanged deep open ocean} ($S$ varies 0.02\,PSU) --- a late consequence of the instability spreading, not a cause. \emph  {Bottom:} the \textbf  {60\,s \texttt  {\small  eta\_n} crash site} (112.8/$-$65.9) is unchanged coastal slope 32\,km from the advanced-ice margin --- a mild state where the barotropic mode piles up over $\sim $10 days.}}{6}{figure.2}\protected@file@percent }
\newlabel{fig:hetero}{{2}{6}{\textbf {Two other high-\code {CFLz} sites --- both benign at $t=0$, confirming the seed is elsewhere.} \emph {Top:} the peak-\code {CFLz} cell (90.5/$-$63.5, level~38, \textbf {3775\,m}) is \textbf {fully-unchanged deep open ocean} ($S$ varies 0.02\,PSU) --- a late consequence of the instability spreading, not a cause. \emph {Bottom:} the \textbf {60\,s \code {eta\_n} crash site} (112.8/$-$65.9) is unchanged coastal slope 32\,km from the advanced-ice margin --- a mild state where the barotropic mode piles up over $\sim $10 days}{figure.2}{}}
